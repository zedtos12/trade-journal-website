# PostgreSQL connection string.
# Local/VPS host example using your exposed Postgres port:
# DATABASE_URL="postgresql://boni:***@localhost:15432/tradingjournal?schema=public"
# Docker Compose network example:
# DATABASE_URL="postgresql://boni:***@postgres:5432/tradingjournal?schema=public"
DATABASE_URL="postgresql://USER:***@HOST:5432/tradingjournal?schema=public"
