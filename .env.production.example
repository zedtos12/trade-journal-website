# Copy this file to .env.production on the VPS host and fill real values there.
# Never commit .env.production.

# If PostgreSQL is an existing separate Docker container exposed to VPS host port 15432,
# use host.docker.internal from the app container and keep the compose extra_hosts entry.
DATABASE_URL="postgresql://USER:STRONG_PASSWORD@host.docker.internal:15432/tradingjournal?schema=public"

# Required for secure cookies and production behavior.
NODE_ENV="production"
